---
import Layout from './Layout.astro';
import { siteConfig } from '../site.config';

const { frontmatter = {} } = Astro.props as { frontmatter?: Record<string, any> };
const {
  title = 'Untitled post',
  description,
  pubDate,
  author = siteConfig.author.name,
  readingTime,
} = frontmatter;

const published =
  pubDate instanceof Date ? pubDate : pubDate ? new Date(pubDate) : null;
const minutes =
  typeof readingTime === 'number'
    ? readingTime
    : readingTime
    ? Number(readingTime)
    : null;

// Build sorted post list for prev/next navigation
type PostModule = {
  frontmatter: { title: string; pubDate?: string };
  url: string;
};
const postImportResult = import.meta.glob('../pages/posts/*.md', { eager: true });
const allPosts = Object.values(postImportResult as Record<string, PostModule>)
  .filter((p) => p.frontmatter.pubDate)
  .sort((a, b) => {
    const da = new Date(a.frontmatter.pubDate!).getTime();
    const db = new Date(b.frontmatter.pubDate!).getTime();
    return db - da; // newest first
  });

const currentIndex = allPosts.findIndex((p) => p.url === Astro.url.pathname.replace(/\/$/, ''));
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const olderPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
---

<Layout title={title}>
  <div class="progress-bar" id="progress-bar" aria-hidden="true" />

  <article class="post">
    <a href="/markdown-blog/blog/" class="back-link">← All Writings</a>

    <header class="post-header">
      <h1>{title}</h1>
      <p class="meta">
        {published && (
          <time datetime={published.toISOString()}>
            {published.toLocaleDateString(undefined, {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        )}
        {author && (
          <span> · {author}</span>
        )}
        {minutes && minutes > 0 && (
          <span> · {minutes} min read</span>
        )}
      </p>
      {description && <p class="description">{description}</p>}
    </header>

    <div class="post-body">
      <slot />
    </div>

    {(olderPost || newerPost) && (
      <nav class="post-nav" aria-label="Post navigation">
        {olderPost ? (
          <a href={olderPost.url} class="post-nav-link prev">
            <span class="post-nav-label">← Previous</span>
            <span class="post-nav-title">{olderPost.frontmatter.title}</span>
          </a>
        ) : (
          <span />
        )}
        {newerPost ? (
          <a href={newerPost.url} class="post-nav-link next">
            <span class="post-nav-label">Next →</span>
            <span class="post-nav-title">{newerPost.frontmatter.title}</span>
          </a>
        ) : (
          <span />
        )}
      </nav>
    )}
  </article>

  <script>
    function setupProgress() {
      const bar = document.getElementById('progress-bar');
      if (!bar) return;
      const update = () => {
        const h = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = h > 0 ? `${Math.min((window.scrollY / h) * 100, 100)}%` : '0%';
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupProgress);
    } else {
      setupProgress();
    }
    document.addEventListener('astro:after-swap', setupProgress);
  </script>

  <style>
    .progress-bar {
      position: fixed;
      top: 0;
      left: 0;
      height: 2px;
      width: 0%;
      background: var(--accent);
      z-index: 200;
      transition: width 0.08s linear;
    }

    .post {
      max-width: var(--max-width);
    }

    .back-link {
      display: inline-block;
      font-size: 0.875rem;
      color: var(--text-muted);
      text-decoration: none;
      margin-bottom: 2rem;
      transition: color var(--transition);
    }

    .back-link:hover {
      color: var(--text);
      text-decoration: none;
    }

    .post-header {
      margin-bottom: 2.5rem;
    }

    h1 {
      font-family: var(--font-serif);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin: 0 0 0.75rem;
    }

    .meta {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin: 0;
    }

    .description {
      margin: 1rem 0 0;
      font-size: 1.0625rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* Post body */
    .post-body {
      font-size: 1.125rem;
      line-height: 1.8;
      color: var(--text);
    }

    .post-body :global(p) {
      margin: 0 0 1.5rem;
    }

    .post-body :global(p:last-child) {
      margin-bottom: 0;
    }

    .post-body :global(h2) {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin: 3rem 0 1rem;
    }

    .post-body :global(h3) {
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 600;
      margin: 2.5rem 0 0.75rem;
    }

    .post-body :global(ul),
    .post-body :global(ol) {
      margin: 0 0 1.5rem;
      padding-left: 1.25rem;
    }

    .post-body :global(li + li) {
      margin-top: 0.375rem;
    }

    .post-body :global(code) {
      font-family: var(--font-mono);
      font-size: 0.875em;
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
      background: var(--code-bg);
    }

    .post-body :global(pre) {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      margin: 1.5rem 0;
      padding: 1.25rem 1.5rem;
      border-radius: 0.5rem;
      background: var(--code-block-bg);
      color: var(--code-block-text);
      overflow-x: auto;
      line-height: 1.6;
    }

    .post-body :global(pre code) {
      background: none;
      padding: 0;
      font-size: inherit;
    }

    .post-body :global(blockquote) {
      margin: 1.5rem 0;
      padding: 0 0 0 1.25rem;
      border-left: 2px solid var(--border);
      font-style: italic;
      color: var(--text-muted);
    }

    .post-body :global(blockquote p) {
      margin: 0;
    }

    .post-body :global(a) {
      color: var(--accent);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.15em;
    }

    .post-body :global(hr) {
      border: none;
      height: 1px;
      background: var(--border);
      margin: 2.5rem 0;
    }

    .post-body :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 0.5rem;
      margin: 1.5rem 0;
    }

    /* Prev / Next navigation */
    .post-nav {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .post-nav-link {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
      text-decoration: none !important;
      color: inherit !important;
      transition: color var(--transition);
    }

    .post-nav-link.next {
      text-align: right;
      align-items: flex-end;
    }

    .post-nav-label {
      font-size: 0.8125rem;
      color: var(--text-muted);
      transition: color var(--transition);
    }

    .post-nav-title {
      font-family: var(--font-serif);
      font-size: 1.0625rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      line-height: 1.3;
      transition: color var(--transition);
    }

    .post-nav-link:hover .post-nav-title {
      color: var(--accent);
    }

    .post-nav-link:hover .post-nav-label {
      color: var(--text);
    }

    @media (max-width: 480px) {
      .post-nav {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }

      .post-nav-link.next {
        text-align: left;
        align-items: flex-start;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
      }
    }
  </style>
</Layout>
